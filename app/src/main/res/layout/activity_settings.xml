<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="AYARLAR"
        android:textColor="#FFD700"
        android:textSize="32sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="32dp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/sw_call_announcer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Arayanı Sesli Söyle"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:padding="16dp"
        android:thumbTint="#FFD700"
        app:trackTint="#555555" />

    <LinearLayout
        android:id="@+id/ll_repeat_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tekrar Sayısı (1-3):"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:layout_marginStart="16dp" />

        <EditText
            android:id="@+id/et_repeat_count"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:inputType="number"
            android:maxLength="1"
            android:textColor="#000000"
            android:background="#FFD700"
            android:padding="12dp"
            android:text="1"
            android:gravity="center" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginVertical="16dp" />

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/sw_background_run"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Arka Planda Çalış"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:padding="16dp"
        android:thumbTint="#FFD700"
        app:trackTint="#555555" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Uygulamanın arka planda aktif kalmasını sağlar."
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="-8dp" />

    <Button
        android:id="@+id/btn_save"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="#FFD700"
        android:text="KAYDET"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold" />

</LinearLayout>
